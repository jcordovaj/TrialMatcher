        "outcomesModule": {
            "primaryOutcomes": [
                {
                    "measure": "Adverse Events",
                    "description": "Treatment-emergent adverse events/serious adverse events/adverse events of special interest",
                    "timeFrame": "Up to approximately 3 years"
                },
                {
                    "measure": "Progression free survival (PFS)",
                    "description": "Defined as the time from the date of randomization to the date of first documentation of progression disease (PD) or the date of death from any cause, whichever occurs first.",
                    "timeFrame": "Up to approximately 3 years"
                }
            ],
            "secondaryOutcomes": [
                {
                    "measure": "Percentage of Participants Achieving Best Overall Response (BOR)",
                    "description": "BOR is defined as Complete Response (CR) or Partial Response (PR), determined by Lugano criteria",
                    "timeFrame": "Up to approximately 3 years"
                },
                {
                    "measure": "Percentage of Participants Achieving CR",
                    "description": "Percentage of participants who achieve a CR determined per Lugano criteria.",
                    "timeFrame": "Up to approximately 3 years"
                },
                {
                    "measure": "Overall Survival (OS)",
                    "description": "Overall survival is defined as the duration from the date of randomization to the date of the participant's death.",
                    "timeFrame": "Up to approximately 3 years"
                },
                {
                    "measure": "Duration of Response (DOR)",
                    "description": "DOR is defined as the time from the first occurrence of response (CR or PR) to disease progression or death, whichever occurs first.",
                    "timeFrame": "Up to approximately 3 years"
                },
                {
                    "measure": "Time to Response (TTR)",
                    "description": "Time to response is defined for participants achieving a CR/PR as the time from starting therapy to first a CR/PR.",
                    "timeFrame": "Up to approximately 3 years"
                },
                {
                    "measure": "Event-Free Survival (EFS)",
                    "description": "EFS is defined as the duration from randomization to disease progression determined by Lugano criteria as assessed by the investigator, initiation of any non-protocol-specified new anti-lymphoma therapy for any reason, or death (whichever occurs first).",
                    "timeFrame": "Up to approximately 3 years"
                },
                {
                    "measure": "Duration of Complete Response (DOCR)",
                    "description": "DOCR is defined as the time from the first occurrence of CR to disease progression or death, whichever occurs first.",
                    "timeFrame": "Up to approximately 3 years"
                },
                {
                    "measure": "Time to Complete Response (TTCR)",
                    "description": "Time to complete response is defined for participants achieving a CR as the time from starting therapy to first a CR.",
                    "timeFrame": "Up to approximately 3 years"
                },
                {
                    "measure": "Blood Concentrations of SCTB35",
                    "description": "The pharmacokinetics of SCTB35 will be analyzed based on the drug concentrations at respective timepoints in the blood samples (or blood derivative)",
                    "timeFrame": "Up to approximately 1 years"
                },
                {
                    "measure": "Anti-drug Antibodies of SCTB35",
                    "description": "Blood samples (or blood derivative) will be screened for antibodies binding to SCTB35",
                    "timeFrame": "Up to approximately 3 years"
                }
            ]
        },
        "eligibilityModule": {
            "eligibilityCriteria": "Inclusion Criteria:\n\n* Age 18-80 years old\n* Histologically confirmed Follicular lymphoma (FL) grade 1, 2, or 3a according to WHO 2022 criteria\n* Relapsed or refractory (R/R) disease to at least one prior systemic regimen that contained an anti-CD20 monoclonal antibody (mAb) in combination with chemotherapy\n* Judged by the investigator, the participant must urgently need to receive systemic treatment, based on meeting at least one GELF criterion\n* A measurable or evaluable disease at the time of enrolment\n* ECOG PS 0-2\n* Adequate organ function and bone marrow function\n* Expected survival ≥ 6 months\n\nExclusion Criteria:\n\n* Documented refractoriness to lenalidomide.\n* Have lenalidomide exposure within 12 months prior to randomization",
            "healthyVolunteers": false,
